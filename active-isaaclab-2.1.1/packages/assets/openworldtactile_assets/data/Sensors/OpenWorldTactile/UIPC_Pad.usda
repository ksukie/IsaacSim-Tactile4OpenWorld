    def Xform "collision"
    {
        def Mesh "membrane_uipc_contact_surface" (
            customData = {
                string role = "uipc_collision_surface_only"
                string solver_owner = "uipc"
                string physx_collision = "disabled"
                string contact_side = "+x"
            }
        )
        {
            token visibility = "invisible"
            uniform token subdivisionScheme = "none"
            bool doubleSided = 1
            custom bool uipc:physx_collision_enabled = 0
            point3f[] points = [
                (0, -0.010375, -0.012625),
                (0, 0.010375, -0.012625),
                (0, -0.010375, 0.012625),
                (0, 0.010375, 0.012625),
            ]
            int[] faceVertexCounts = [3, 3]
            int[] faceVertexIndices = [
                0, 1, 2,
                1, 3, 2,
            ]
        }

    }

    def Xform "simulation" (
        customData = {
            string role = "uipc_solver_inputs"
        }
    )
    {
        custom asset uipc:tet_mesh = @./uipc/membrane.tet@
        custom asset uipc:surface_mesh = @./uipc/membrane_surface.obj@
        custom bool uipc:external_mesh_required = 0
        custom token uipc:missing_external_mesh_policy = "fallback_to_membrane_sim_mesh"
        custom token uipc:solver_mesh_status = "placeholder"
        custom token uipc:write_back_mode = "points_only"
        custom token[] uipc:updated_attributes = ["points"]
        rel uipc:visual_target = </UIPC_Pad/visual/membrane_camera_surface>
        rel uipc:collision_target = </UIPC_Pad/collision/membrane_uipc_contact_surface>
        def Mesh "membrane_sim_mesh" (
            customData = {
                string role = "uipc_tet_source_surface_placeholder"
                string units = "SI"
                double attachment_radius_m = 0.0005
                double attachment_strength_ratio = 500
                double mass_density_kg_per_m3 = 1050
                double membrane_thickness_m = 0.0005
                double poisson_ratio = 0.49
                double tet_edge_length_ratio_to_min_dimension = 0.016666666666666666
                double tet_epsilon_ratio_to_membrane_thickness = 0.0005
                double youngs_modulus_pa = 50000
            }
        )
        {
            token visibility = "inherited"
            uniform token subdivisionScheme = "none"
            bool doubleSided = 1
            rel material:binding = </UIPC_Pad/materials/membrane_tactile_sim_red_material>
            color3f[] primvars:displayColor = [(1, 0, 0)]
            float[] primvars:displayOpacity = [1]
            point3f[] points = [
                (-0.0005, -0.010375, -0.012625),
                (-0.0005, 0.010375, -0.012625),
                (-0.0005, -0.010375, 0.012625),
                (-0.0005, 0.010375, 0.012625),
                (0, -0.010375, -0.012625),
                (0, 0.010375, -0.012625),
                (0, -0.010375, 0.012625),
                (0, 0.010375, 0.012625),
            ]
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [
                0, 2, 1,
                1, 2, 3,
                4, 5, 6,
                5, 7, 6,
                0, 1, 4,
                1, 5, 4,
                2, 6, 3,
                3, 6, 7,
                0, 4, 2,
                2, 4, 6,
                1, 3, 5,
                3, 7, 5,
            ]
        }

        def Xform "fixed_node_set" (
            customData = {
                string role = "uipc_fixed_back_face_selector"
                string selection_rule = "select membrane_sim_mesh vertices with x <= fixed_x_m + selection_epsilon_m"
            }
        )
        {
            custom double fixed_x_m = -0.0005
            custom double selection_epsilon_m = 0.00008
            rel target_mesh = </UIPC_Pad/simulation/membrane_sim_mesh>
        }
    }

    def Xform "sensors"
    {
        def Camera "camera" (
            customData = {
                string role = "internal_visual_tactile_camera"
            }
        )
        {
            float focalLength = 1.5
            float focusDistance = 0.0015
            float horizontalAperture = 25.25
            float verticalAperture = 20.75
            float2 clippingRange = (0.00002, 0.015)
            double3 xformOp:translate = (-0.002, 0, 0)
            quatd xformOp:orient = (0.7071068, 0, -0.7071068, 0)
            uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient"]
        }
    }

    def Scope "materials"
    {
        def Material "membrane_tactile_sim_red_material"
        {
            token outputs:surface.connect = </UIPC_Pad/materials/membrane_tactile_sim_red_material/PreviewSurface.outputs:surface>

            def Shader "PreviewSurface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (1, 0, 0)
                color3f inputs:emissiveColor = (0.45, 0, 0)
                float inputs:metallic = 0
                float inputs:opacity = 1
                float inputs:roughness = 0.75
                token outputs:surface
            }
        }

        def Material "membrane_camera_black_material"
        {
            token outputs:surface.connect = </UIPC_Pad/materials/membrane_camera_black_material/PreviewSurface.outputs:surface>

            def Shader "PreviewSurface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0, 0, 0)
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:metallic = 0
                float inputs:opacity = 0.22
                float inputs:roughness = 1
