#usda 1.0
(
    defaultPrim = "UIPC_Pad"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "UIPC_Pad" (
    customData = {
        string asset_kind = "standalone_uipc_pad"
        string bridge_contract = "uipc_pad_bridge_v1"
        string coordinate_frame = "+x contact normal, +y width, +z length; camera is on -x looking +x"
        string role = "robot_mount_datum"
        string solver_role = "external_uipc_solver_asset"
        string source_layout = "OpenWorldTactile_v2_7 defaults"
        double anchor_thickness_m = 0.001
        double membrane_back_x_m = -0.0005
        double membrane_front_x_m = 0
        double membrane_length_m = 0.02525
        double membrane_thickness_m = 0.0005
        double membrane_width_m = 0.02075
        string display_layer_contract = "USD-authored membrane debug display: camera_surface black, visual_back_mesh green, membrane_sim_mesh red tactile source. Visibility can be changed on the mesh visibility token; default opacity/color values are mirrored by openworldtactile:display:* custom attrs."
        double visual_surface_x_m = -0.0017
        double visual_texture_x_m = -0.00172
    }
)
{
    custom bool openworldtactile:display:show_camera_surface = 1
    custom bool openworldtactile:display:show_visual_back_mesh = 1
    custom bool openworldtactile:display:show_tactile_sim_membrane = 1
    custom color3f openworldtactile:display:camera_surface_color = (0, 0, 0)
    custom color3f openworldtactile:display:visual_back_mesh_color = (0, 0.95, 0.2)
    custom color3f openworldtactile:display:tactile_sim_membrane_color = (1, 0, 0)
    custom float openworldtactile:display:camera_surface_opacity = 0.22
    custom float openworldtactile:display:visual_back_mesh_opacity = 0.85
    custom float openworldtactile:display:tactile_sim_membrane_opacity = 1

    def Xform "mount_frame" (
        customData = {
            string role = "legacy_identity_mount_frame"
            string note = "Compatibility identity frame. Bridge and robot mounting should use /UIPC_Pad as the mount datum."
        }
    )
    {
        double3 xformOp:translate = (0, 0, 0)
        quatd xformOp:orient = (1, 0, 0, 0)
        double3 xformOp:scale = (1, 1, 1)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale"]
    }

    def Xform "rigid_base" (
        customData = {
            string role = "backing_anchor"
            string simulation_meaning = "Rigid backing used to define the fixed side of the UIPC membrane."
        }
    )
    {
        def Mesh "mesh"
