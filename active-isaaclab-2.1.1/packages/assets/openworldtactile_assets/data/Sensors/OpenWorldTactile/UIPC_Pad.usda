            }
        }

        def Material "backing_material"
        {
            token outputs:surface.connect = </UIPC_Pad/materials/backing_material/PreviewSurface.outputs:surface>

            def Shader "PreviewSurface"
            {
                uniform token info:id = "UsdPreviewSurface"
